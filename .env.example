# 🎲 SOLI-DM FRONTEND — Environment Variables
# Copia questo file a .env.local e riempilo con i tuoi valori
# Le variabili con NEXT_PUBLIC_ sono esposte al client (sicure da condividere)

# ========== BACKEND API ==========
# URL del backend API (Express, default locale porta 5000)
NEXT_PUBLIC_API_URL=http://localhost:5000
# In produzione: https://soli-dm-be.onrender.com

# Se sul backend imposti SOLI_DM_API_KEY, qui la stessa chiave (esposta al client).
# In produzione preferisci un BFF Next che aggiunge l'header lato server.
# NEXT_PUBLIC_SOLI_DM_API_KEY=

# ========== SUPABASE (Autenticazione + Database Client) ==========
# Ottieni questi valori da https://supabase.com/dashboard → Progetto → Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# ⚠️ Usa ANON_KEY (il valore PUBLIC), non SERVICE_KEY!
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Opzionale — Service Key per operazioni server-side (next/ssr only)
# SUPABASE_SERVICE_KEY=your-service-key-here
# ⚠️ PRIVATO — Non esporre al client!

# ========== AUTENTICAZIONE GOOGLE ==========
# Google OAuth Client ID (configurato in Supabase)
# Non serve nel .env — usa Supabase Auth direttamente
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id

# ========== ANALYTICS (Opzionale) ==========
NEXT_PUBLIC_GA_ID=
# Ga
# Google Analytics 4 ID — Lascia vuoto se non usi

# ========== SENTRY (Opzionale — Error Tracking) ==========
NEXT_PUBLIC_SENTRY_DSN=
# Lascia vuoto se non usi Sentry

# ========== APP MODE ==========
NEXT_PUBLIC_APP_ENV=development
# Valori: development, staging, production
